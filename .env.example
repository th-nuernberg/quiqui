# Obscure path segment for the host page — change this before deploying
HOST_SLUG=host-x46pd

# Default question repo URL pre-filled in the teacher page repo input
DEFAULT_REPO_URL=https://github.com/th-nuernberg/quiqui-questions

# Port to listen on
PORT=3000

# Reverse-proxy subpath the app is served under, WITHOUT a trailing slash
# (e.g. /quiqui). Set this ONLY when a proxy forwards a subpath without
# stripping it. Leave unset when the app owns the domain root (the default).
# BASE_PATH=

# Log level: INFO (default) or ERROR (suppress info messages)
LOG_LEVEL=INFO

# Idle session lifetime in minutes before state + cloned files are dropped
# Default: 90
# SESSION_TIMEOUT_MINUTES=90

# Size limits, all in KB. Defaults shown. Raise these if question repos ship
# larger images; REPO is checked via the GitHub API before cloning.
# REPO_SIZE_LIMIT_KB=1024    # whole question repo (1 MB)
# FILE_SIZE_LIMIT_KB=100     # a single question YAML file
# IMAGE_SIZE_LIMIT_KB=512    # a single image served from the pulled clone

# Impressum — set these in your deployment environment (e.g. Render dashboard)
# Unset fields are shown as highlighted placeholders on the page
IMPRESSUM_NAME=
IMPRESSUM_INSTITUTION=
IMPRESSUM_DEPARTMENT=
IMPRESSUM_STREET=
IMPRESSUM_CITY=
IMPRESSUM_EMAIL=
